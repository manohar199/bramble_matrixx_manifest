<?xml version="1.0" encoding="UTF-8"?>
<manifest>
  <!-- Remote definition for GitHub -->
  <remote name="github"
          fetch="https://github.com/"
          review="github.com" />

  <!-- Default settings -->
  <default revision="main"
           remote="github"
           sync-j="4" />

  <!-- Kernel repository for redbull (Pixel 4a 5G / Pixel 5) -->
  <project path="kernel/google/redbull"
           name="manohar199/android_kernel_google_redbull"
           remote="github"
           revision="ksu-legacy-16.2" />

  <!-- Device tree for bramble (Pixel 5) -->
  <project path="device/google/bramble"
           name="manohar199/android_device_google_bramble"
           remote="github"
           revision="bramble" />

  <!-- Proprietary vendor blobs for bramble -->
  <project path="vendor/google/bramble"
           name="manohar199/proprietary_vendor_google_bramble"
           remote="github"
           revision="lineage-22.2" />

  <!-- Optional: Add AOSP base if you need a full build environment -->
  <!--
  <include name="https://source.android.com/source/manifest.xml" />
  -->
</manifest>
